# Build artifacts
obj/
obj_rtg/
build/
*.o
*.a
*.so
*.exe

# Rust build artifacts
target/
**/target/

# Python cache
__pycache__/
*.pyc
*.pyo

# ROM images - never tracked
*.bin
roms/
*.rom

# Debug output
*.ppm

# Binary executables (AmigaOS loadseg or ELF) -- anchor to the game-root exe so
# these patterns do NOT also match the Shinobi/ game DIRECTORY (which must be tracked).
/Shinobi/Shinobi
/Golden_Axe/GoldenAxe

# IDE / editor
*.swp
*.swo
*~
.DS_Store
.vscode/
.idea/

# HDF disk images
*.hdf
*.uae
*.zip
/Shadow_Dancer/ShadowDancer
/Alien_Syndrome/AlienSyndrome
